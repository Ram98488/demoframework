{
  "compilerOptions": {
    "module": "commonjs",
    "target": "esnext",
    "types": ["node", "@playwright/test"],

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,

    "verbatimModuleSyntax": false
  }
}